<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<!-- CHANGED to Exe so the terminal window shows for your password -->
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<UseWindowsForms>true</UseWindowsForms>
	</PropertyGroup>

	<!-- This keeps the old WinForms files from clashing with your WPF code -->
	<ItemGroup>
		<Compile Remove="ChatbotForm.cs" />
		<Compile Remove="ChatbotForm.Designer.cs" />
		<EmbeddedResource Remove="ChatbotForm.resx" />
	</ItemGroup>
	<ItemGroup>
	  <None Remove="greeting.m4a.wav" />
	</ItemGroup>
	<ItemGroup>
	  <Content Include="greeting.m4a.wav">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>
	<ItemGroup>
	  <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.9" />
	  <PackageReference Include="MySql.Data" Version="9.7.0" />
	</ItemGroup>

</Project>